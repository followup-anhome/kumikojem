// KUMIKOJEM - Prisma Schema
// フィリピン人材 × 日本企業 × 不動産マッチング

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// 求人 (Job)
// ─────────────────────────────────────────
enum JobCategory {
  LOGISTICS     // 運送・物流
  CONSTRUCTION  // 建設・土木
  CARE          // 福祉・介護
  FACTORY       // 製造・工場
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

model Job {
  id             String      @id @default(cuid())
  title          String
  description    String?     @db.Text
  category       JobCategory
  salary_min     Int?        // 月給下限 (円)
  salary_max     Int?        // 月給上限 (円)
  location_name  String      // 勤務地名称 (例: 大阪市北区)
  location_lat   Float       // 緯度
  location_lng   Float       // 経度
  housing_status Boolean     @default(false) // 社宅・寮あり
  company_name   String?
  source_pdf_url String?     // 元の求人票PDF URL
  status         JobStatus   @default(OPEN)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  // Relations
  matches        Match[]
  properties     PropertyRecommendation[]

  @@index([category])
  @@index([location_lat, location_lng])
  @@index([status])
}

// ─────────────────────────────────────────
// 人材 (Talent) — フィリピン側
// ─────────────────────────────────────────
enum Gender {
  MALE
  FEMALE
  OTHER
}

model Talent {
  id                 String    @id @default(cuid())
  name               String
  name_kana          String?   // カタカナ
  gender             Gender
  birth_date         DateTime?
  height_cm          Float?    // 身長 (cm) — 建設・運送適性に使用
  weight_kg          Float?    // 体重 (kg)
  nationality        String    @default("Philippines")
  fb_profile_url     String?   // Facebook プロフィールURL (現地確認用)
  certificates       String[]  // 資格リスト (例: ["N3", "介護福祉士", "大型免許"])
  suitability_score  Float     @default(0.0) // AI算出の現場適性スコア (0.0 ~ 1.0)
  availability_date  DateTime? // 就業可能日
  desired_salary_min Int?      // 希望月給下限
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  // Relations
  matches            Match[]

  @@index([suitability_score])
  @@index([gender])
}

// ─────────────────────────────────────────
// 不動産物件 (Property) — アンホーム連携
// ─────────────────────────────────────────
enum ManagementCompany {
  AN_HOME         // アンホーム (一建設系)
  EXTERNAL        // 外部物件
}

model Property {
  id                 String            @id @default(cuid())
  name               String            // 物件名
  address            String            // 住所
  lat                Float             // 緯度
  lng                Float             // 経度
  rent               Int               // 月額賃料 (円)
  management_company ManagementCompany @default(AN_HOME)
  floor_plan         String?           // 間取り (例: "1K", "2DK")
  max_occupancy      Int?              // 最大居住人数
  available          Boolean           @default(true)
  external_url       String?           // 物件詳細ページURL
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  // Relations
  recommendations    PropertyRecommendation[]

  @@index([lat, lng])
  @@index([available])
  @@index([management_company])
}

// ─────────────────────────────────────────
// マッチング (Match)
// ─────────────────────────────────────────
enum MatchStatus {
  PENDING     // 提案済み
  REVIEWING   // 企業確認中
  ACCEPTED    // 採用内定
  REJECTED    // 見送り
  WITHDRAWN   // 辞退
}

model Match {
  id           String      @id @default(cuid())
  job_id       String
  talent_id    String
  score        Float       // マッチングスコア (0.0 ~ 1.0)
  status       MatchStatus @default(PENDING)
  notes        String?     @db.Text
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  job          Job         @relation(fields: [job_id], references: [id])
  talent       Talent      @relation(fields: [talent_id], references: [id])

  @@unique([job_id, talent_id])
  @@index([status])
  @@index([score])
}

// ─────────────────────────────────────────
// ビザ種別 (VisaType)
// ─────────────────────────────────────────
enum VisaType {
  SPECIFIED_SKILLED_1  // 特定技能1号
  SPECIFIED_SKILLED_2  // 特定技能2号
  TECHNICAL_INTERN     // 技能実習
  ENGINEER             // 技術・人文知識・国際業務
  PERMANENT_RESIDENT   // 永住者
  STUDENT              // 留学
  SPOUSE               // 配偶者ビザ
  OTHER
}

// ─────────────────────────────────────────
// 日本語レベル (JapaneseLevel)
// ─────────────────────────────────────────
enum JapaneseLevel {
  N1
  N2
  N3
  N4
  N5
  NONE
}

// ─────────────────────────────────────────
// 英語レベル (EnglishLevel)
// ─────────────────────────────────────────
enum EnglishLevel {
  BUSINESS  // ビジネスレベル
  DAILY     // 日常会話
  BASIC     // 基礎
  NONE      // なし
}

// ─────────────────────────────────────────
// 給与形態 (SalaryType)
// ─────────────────────────────────────────
enum SalaryType {
  MONTHLY  // 月給
  HOURLY   // 時給
}

// ─────────────────────────────────────────
// 業種 (IndustryType)
// ─────────────────────────────────────────
enum IndustryType {
  LOGISTICS     // 運送・物流
  CONSTRUCTION  // 建設・土木
  CARE          // 福祉・介護
  FACTORY       // 製造・工場
  OTHER
}

// ─────────────────────────────────────────
// 応募ステータス (ApplicationStatus)
// ─────────────────────────────────────────
enum ApplicationStatus {
  APPLIED     // 応募済み
  REVIEWING   // 書類選考中
  INTERVIEW   // 面談予定
  OFFERED     // 内定
  REJECTED    // 不採用
  WITHDRAWN   // 辞退
}

// ─────────────────────────────────────────
// 求職者 (User)
// ─────────────────────────────────────────
model User {
  id                  String         @id @default(cuid())
  name                String
  nationality         String         @default("Philippines")
  gender              Gender?
  height_cm           Float?
  weight_kg           Float?
  visa_type           VisaType       @default(OTHER)
  japanese_level      JapaneseLevel  @default(NONE)
  english_level       EnglishLevel   @default(NONE)
  skills              String[]
  certs               String[]
  desired_prefecture  String?
  salary_type         SalaryType?
  desired_salary      Int?
  bio_ja              String?        @db.Text
  bio_en              String?        @db.Text
  photo_url           String?
  fb_profile_url      String?
  fb_score            Float?
  email               String?        @unique
  phone               String?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  applications        Application[]

  @@index([visa_type])
  @@index([japanese_level])
  @@index([english_level])
}

// ─────────────────────────────────────────
// 受入企業 (Company)
// ─────────────────────────────────────────
model Company {
  id             String       @id @default(cuid())
  name           String
  industry       IndustryType
  location       String
  accepted_visas VisaType[]
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  job_postings   JobPosting[]
  users          CompanyUser[]
}

model CompanyUser {
  id            String   @id @default(cuid())
  company_id    String
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  company       Company  @relation(fields: [company_id], references: [id])
  @@index([company_id])
}

// ─────────────────────────────────────────
// 求人票 (JobPosting)
// ─────────────────────────────────────────
model JobPosting {
  id              String       @id @default(cuid())
  company_id      String
  title           String
  description     String?      @db.Text
  salary_min      Int?         // 月給下限 (円)
  salary_max      Int?         // 月給上限 (円)
  salary_type     SalaryType?
  location        String
  required_skills String[]
  accepted_visas  VisaType[]
  status          JobStatus    @default(OPEN)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  company         Company      @relation(fields: [company_id], references: [id])
  applications    Application[]

  @@index([company_id])
  @@index([status])
}

// ─────────────────────────────────────────
// 応募 (Application)
// ─────────────────────────────────────────
model Application {
  id             String            @id @default(cuid())
  user_id        String
  job_posting_id String
  status         ApplicationStatus @default(APPLIED)
  interview_at   DateTime?         // 面談日時
  notes          String?           @db.Text
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  user           User              @relation(fields: [user_id], references: [id])
  job_posting    JobPosting        @relation(fields: [job_posting_id], references: [id])

  @@unique([user_id, job_posting_id])
  @@index([status])
  @@index([interview_at])
}

// ─────────────────────────────────────────
// 物件推薦ログ (PropertyRecommendation)
// ─────────────────────────────────────────
model PropertyRecommendation {
  id           String   @id @default(cuid())
  job_id       String
  property_id  String
  distance_km  Float    // 勤務地からの距離 (km)
  created_at   DateTime @default(now())

  job          Job      @relation(fields: [job_id], references: [id])
  property     Property @relation(fields: [property_id], references: [id])

  @@unique([job_id, property_id])
  @@index([distance_km])
}
